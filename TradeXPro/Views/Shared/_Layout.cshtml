<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TradeX Pro</title>
    <script>
        // Apply theme immediately to prevent flash of wrong theme
        (function() {
            var theme = localStorage.getItem('tradexpro-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="dashboard">
        <!-- Header -->
        <header class="header">
            <div class="header-left">
                <div class="logo">TradeX Pro</div>
                <nav class="nav">
                    <a asp-controller="Home" asp-action="Index" class="@(ViewData["ActivePage"] == null ? "active" : "")">Dashboard</a>
                    <a asp-controller="Home" asp-action="Markets" class="@(ViewData["ActivePage"]?.ToString() == "Markets" ? "active" : "")">Markets</a>
                    <a asp-controller="Home" asp-action="Portfolio" class="@(ViewData["ActivePage"]?.ToString() == "Portfolio" ? "active" : "")">Portfolio</a>
                    <a asp-controller="Home" asp-action="Orders" class="@(ViewData["ActivePage"]?.ToString() == "Orders" ? "active" : "")">Orders</a>
                    <a asp-controller="Home" asp-action="History" class="@(ViewData["ActivePage"]?.ToString() == "History" ? "active" : "")">History</a>
                    <a asp-controller="Home" asp-action="Screener" class="@(ViewData["ActivePage"]?.ToString() == "Screener" ? "active" : "")">Screener</a>
                    <a asp-controller="Home" asp-action="News" class="@(ViewData["ActivePage"]?.ToString() == "News" ? "active" : "")">News</a>
                    <a asp-controller="Home" asp-action="Alerts" class="@(ViewData["ActivePage"]?.ToString() == "Alerts" ? "active" : "")">Alerts</a>
                    <a asp-controller="Home" asp-action="Analytics" class="@(ViewData["ActivePage"]?.ToString() == "Analytics" ? "active" : "")">Analytics</a>
                </nav>
            </div>
            <div class="header-right">
                <div class="balance" id="accountBalance">$124,563.82</div>
                <button class="theme-toggle" id="themeToggle" title="Toggle theme">
                    <span class="icon-moon">&#9790;</span>
                    <span class="icon-sun">&#9728;</span>
                </button>
                <a asp-controller="Home" asp-action="Account" class="header-icon-link" title="Account">
                    <div class="header-icon">&#9733;</div>
                </a>
                <a asp-controller="Home" asp-action="Settings" class="header-icon-link" title="Settings">
                    <div class="header-icon">&#9881;</div>
                </a>
                <div class="avatar">JD</div>
            </div>
        </header>

        <!-- Main Content -->
        <div class="main @(ViewData["ActivePage"] != null ? "main-fullpage" : "")">
            @RenderBody()
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
